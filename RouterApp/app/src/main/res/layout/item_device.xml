<?xml version="1.0" encoding="utf-8"?>
<!--
    Single row in the Connected Devices list.

    Layout:
      [●]  token-prefix…               joined 10:02
           status pill (ONLINE / OFFLINE)   last seen 3s ago
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Online-status dot -->
        <TextView
            android:id="@+id/tvStatusDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textSize="16sp"
            android:textColor="@color/colorSuccess"
            android:layout_marginEnd="10dp" />

        <!-- Token + joined-time column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDeviceToken"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="a3f9c2d1…"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvDeviceJoined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="joined 10:02"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary" />

        </LinearLayout>

        <!-- Status pill + last-seen column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvDeviceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONLINE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@color/colorSuccess"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tvDeviceLastSeen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="last seen 3s ago"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
